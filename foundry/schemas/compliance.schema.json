{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nexus/compliance",
  "title": "Nexus Compliance Configuration",
  "description": "Rules for KYC/AML compliance, transaction limits, and regulatory thresholds.",
  "type": "object",
  "properties": {
    "kyc": {
      "type": "object",
      "properties": {
        "tiers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tier": { "type": "integer", "minimum": 0, "maximum": 5 },
              "label": { "type": "string" },
              "daily_limit": { "type": "number", "minimum": 0 },
              "monthly_limit": { "type": "number", "minimum": 0 },
              "card_eligible": { "type": "boolean" },
              "exchange_eligible": { "type": "boolean" }
            },
            "required": ["tier", "label", "daily_limit", "monthly_limit"]
          }
        },
        "required_for_card_issuance": { "type": "integer", "minimum": 1 },
        "statuses": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["pending", "submitted", "under_review", "approved", "rejected"]
          }
        }
      },
      "required": ["tiers", "required_for_card_issuance"]
    },
    "aml": {
      "type": "object",
      "properties": {
        "ctr_threshold": {
          "type": "number",
          "description": "Currency Transaction Report threshold (e.g., $10,000 for US)"
        },
        "velocity_window_hours": { "type": "integer", "minimum": 1 },
        "max_transactions_per_window": { "type": "integer", "minimum": 1 },
        "flagged_amount_multiple": {
          "type": "number",
          "description": "Flag transactions exceeding this multiple of user average"
        }
      },
      "required": ["ctr_threshold", "velocity_window_hours"]
    },
    "transaction_limits": {
      "type": "object",
      "properties": {
        "max_deposit_amount": { "type": "number" },
        "max_exchange_amount": { "type": "number" },
        "max_transfer_amount": { "type": "number" }
      }
    },
    "jurisdictions": {
      "type": "array",
      "description": "Jurisdiction-specific compliance overrides (FATF risk-based approach).",
      "items": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "enum": ["US", "EU", "UK", "JP", "AE", "BR", "DEFAULT"]
          },
          "label": { "type": "string" },
          "ctr_threshold": { "type": "number", "minimum": 0 },
          "ctr_currency": { "type": "string" },
          "max_deposit_without_edd": { "type": "number", "minimum": 0 },
          "max_exchange_amount": { "type": "number", "minimum": 0 },
          "min_card_kyc_tier": { "type": "integer", "minimum": 1 },
          "required_id_types": {
            "type": "array",
            "items": { "type": "string" }
          },
          "velocity_window": {
            "type": "object",
            "properties": {
              "max_transactions": { "type": "integer", "minimum": 1 },
              "window_hours": { "type": "integer", "minimum": 1 }
            },
            "required": ["max_transactions", "window_hours"]
          },
          "structuring_detection": {
            "type": "object",
            "properties": {
              "window_hours": { "type": "integer" },
              "threshold_multiple": {
                "type": "number",
                "description": "Fraction of CTR threshold that triggers structuring alert (e.g., 0.8)"
              }
            }
          },
          "data_protection": {
            "type": "string",
            "enum": ["GDPR", "CCPA", "PIPL", "LGPD", "PIPA", "NONE"]
          },
          "edd_required": {
            "type": "boolean",
            "description": "Whether enhanced due diligence is required for all customers in this jurisdiction"
          }
        },
        "required": ["code", "label", "ctr_threshold", "ctr_currency"]
      }
    },
    "risk_scoring": {
      "type": "object",
      "description": "Risk assessment configuration for transaction scoring.",
      "properties": {
        "levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          }
        },
        "factors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "weight": { "type": "integer", "minimum": 0, "maximum": 30 },
              "description": { "type": "string" }
            },
            "required": ["name", "weight"]
          }
        },
        "thresholds": {
          "type": "object",
          "properties": {
            "edd_required_score": { "type": "integer" },
            "manual_review_score": { "type": "integer" },
            "auto_block_score": { "type": "integer" }
          }
        }
      }
    }
  },
  "required": ["kyc", "aml"]
}
