# =============================================================================
# Nexus Bitcoin Banking Platform — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Application ---
NEXT_PUBLIC_APP_NAME=Nexus Financial
NEXT_PUBLIC_MOCK_MODE=true

# --- Webhook Secrets (HMAC-SHA256) ---
BANKING_WEBHOOK_SECRET=
KYC_WEBHOOK_SECRET=
CARD_WEBHOOK_SECRET=

# --- Cron Authentication ---
CRON_SECRET=

# --- Provider API Keys ---
EMAIL_PROVIDER_KEY=
CARD_PROVIDER_KEY=
EXCHANGE_PROVIDER_KEY=
KYC_PROVIDER_KEY=
BANKING_PROVIDER_KEY_US=
