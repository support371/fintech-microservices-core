{
  "version": 2,
  "builds": [
    {
      "src": "api/converter_service/main.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "api/card_platform_service/main.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    }
  ],
  "routes": [
    {
      "src": "/api/converter/(.*)",
      "dest": "/api/converter_service/main.py"
    },
    {
      "src": "/api/platform/(.*)",
      "dest": "/api/card_platform_service/main.py"
    }
  ]
}
