{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/card_service.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/converter_service.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "/api/card_service.py"
    },
    {
      "src": "/webhook/(.*)",
      "dest": "/api/converter_service.py"
    },
    {
      "src": "/internal/(.*)",
      "dest": "/api/converter_service.py"
    },
    {
      "src": "/health",
      "dest": "/api/index.py"
    },
    {
      "src": "/",
      "dest": "/api/index.py"
    }
  ]
}
