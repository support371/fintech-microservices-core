{
  "version": 2,
  "builds": [
    {
      "src": "api/converter_service/main.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "api/card_platform_service/main.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    }
  ],
  "routes": [
    {
      "src": "/api/converter/(.*)",
      "dest": "/api/converter_service/main.py"
    },
    {
      "src": "/api/platform/(.*)",
      "dest": "/api/card_platform_service/main.py"
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "/api/card_service.py"
    },
    {
      "source": "/webhook/(.*)",
      "destination": "/api/converter_service.py"
    },
    {
      "source": "/internal/(.*)",
      "destination": "/api/converter_service.py"
    },
    {
      "source": "/health",
      "destination": "/api/index.py"
    },
    {
      "source": "/",
      "destination": "/api/index.py"
    }
  ]
}
